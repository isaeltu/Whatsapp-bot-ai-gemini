# API key de Gemini (Google AI Studio -> Get API key)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de Gemini a usar. gemini-flash-lite-latest es el mas barato/rapido
# que sigue dando buena calidad para clasificar intencion y responder.
GEMINI_MODEL=gemini-flash-lite-latest

# Mismo proyecto de Supabase que usa RestoPOS (Settings -> API en el dashboard).
# La anon key es publica (es la misma que viaja en el bundle del frontend),
# no es necesario tratarla como secreto.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx

# Puerto del endpoint de salud (/health). Opcional.
PORT=5000

# Redis (Upstash, plan gratis) -- memoria de conversacion y rate-limit por
# numero. Crear en https://upstash.com -> Redis -> Create Database -> pestana
# "REST API", copiar estos 2 valores.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tope de mensajes por minuto por numero de telefono antes de cortar (evita
# abuso/costo descontrolado de la API de Gemini). Opcional, default 12.
RATE_LIMIT_MESSAGES_PER_MINUTE=12

# Solo si vas a correr MAS DE UN restaurante desde esta misma maquina/codigo:
# un identificador unico por restaurante (namespacea la sesion de WhatsApp,
# evita que dos corridas se pisen). Cada restaurante necesita su propio
# PORT y su propio BOT_CLIENT_ID; GEMINI_API_KEY y SUPABASE_* se mantienen
# iguales para todos. Dejar vacio si es un solo restaurante.
BOT_CLIENT_ID=
