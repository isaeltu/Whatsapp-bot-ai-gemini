# API key de Gemini (Google AI Studio -> Get API key)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de Gemini a usar. gemini-flash-lite-latest es el mas barato/rapido
# que sigue dando buena calidad para clasificar intencion y responder.
GEMINI_MODEL=gemini-flash-lite-latest

# Mismo proyecto de Supabase que usa RestoPOS (Settings -> API en el dashboard).
# La anon key es publica (es la misma que viaja en el bundle del frontend),
# no es necesario tratarla como secreto.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx

# Puerto del servidor HTTP (webhook + /health). Opcional.
PORT=5000

# --- WhatsApp Cloud API (Meta) ---
# Token de acceso permanente (System User, sin expiracion) generado en Meta
# Business Settings. Para pruebas rapidas sirve el temporal de 24h que da
# "API Setup" en developers.facebook.com, pero hay que regenerarlo cada dia.
META_WHATSAPP_ACCESS_TOKEN=

# String que TU inventas (cualquier valor largo al azar). Tiene que coincidir
# exactamente con el "Verify token" que pegues al configurar el webhook en
# Meta -- no es secreto, solo tiene que coincidir en los dos lados.
META_VERIFY_TOKEN=

# "App secret" de la app de Meta (developers.facebook.com -> tu app ->
# Configuracion basica -> App secret). Se usa para validar la firma
# X-Hub-Signature-256 de cada webhook entrante y rechazar payloads falsos.
# Sin esto, CUALQUIERA que adivine la URL del webhook puede mandar pedidos
# falsos. Obligatorio en produccion.
META_APP_SECRET=

# Version de la Graph API de Meta a usar. Opcional, default v21.0.
META_API_VERSION=v21.0

# Clave para proteger /health y /control (pausar/reanudar el bot sin
# redeploy). Sin esto configurado, CUALQUIERA que encuentre esa URL puede ver
# el estado del bot o pausarlo. Pon cualquier string largo al azar y usa la
# misma URL con ?token=<esto> para verlas.
BOT_ADMIN_TOKEN=

# Redis (Upstash, plan gratis) -- memoria de conversacion y rate-limit por
# numero. Crear en https://upstash.com -> Redis -> Create Database -> pestana
# "REST API", copiar estos 2 valores.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tope de mensajes por minuto por numero de telefono antes de cortar (evita
# abuso/costo descontrolado de la API de Gemini). Opcional, default 12.
RATE_LIMIT_MESSAGES_PER_MINUTE=12
